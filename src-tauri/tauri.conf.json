{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PasteFlow",
  "version": "0.1.0",
  "identifier": "com.pasteflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PasteFlow",
        "width": 900,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "resizable": true,
        "visible": true
      },
      {
        "label": "quick-paste",
        "title": "Quick Paste",
        "width": 550,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "queue-indicator",
        "title": "Queue",
        "width": 100,
        "height": 100,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "transparent": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.openai.com https://api.anthropic.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}